<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppFarmaFacil.Views.DetalhesUnidade"
             Title="Detalhes da Unidade"
             BackgroundColor="#F0F4F8">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Banner com nome da unidade -->
            <VerticalStackLayout BackgroundColor="#1565C0"
                                 Padding="20,24,20,24"
                                 Spacing="4">
                <Label x:Name="lblNomeUnidade"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                <Label Text="🏥 Unidade de Saúde"
                       TextColor="#BBDEFB"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Card: Disponibilidade do medicamento -->
            <Border Margin="16,16,16,8"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="💊 Medicamento disponível"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="#1A237E"/>
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>
                    <Label x:Name="lblNomeMedicamento"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#333"/>
                    <Label x:Name="lblPrincipioAtivo"
                           FontSize="13"
                           TextColor="#666"/>
                    <Border BackgroundColor="#E8F5E9"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            Padding="12,8"
                            Margin="0,4,0,0">
                        <Label x:Name="lblQuantidade"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2E7D32"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Card: Informações da unidade -->
            <Border Margin="16,8,16,8"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="ℹ️ Informações da Unidade"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="#1A237E"/>
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>

                    <!-- Endereço -->
                    <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="📍" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Endereço" FontSize="11" TextColor="#999" FontAttributes="Bold"/>
                            <Label x:Name="lblEndereco" FontSize="14" TextColor="#333"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Telefone -->
                    <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="📞" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Telefone" FontSize="11" TextColor="#999" FontAttributes="Bold"/>
                            <Label x:Name="lblTelefone" FontSize="14" TextColor="#333"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Horário -->
                    <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="🕐" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Horário de Funcionamento" FontSize="11" TextColor="#999" FontAttributes="Bold"/>
                            <Label x:Name="lblHorario" FontSize="14" TextColor="#333"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Distância (se disponível) -->
                    <Grid x:Name="gridDistancia" ColumnDefinitions="24,*" ColumnSpacing="8" IsVisible="False">
                        <Label Grid.Column="0" Text="🗺️" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Distância aproximada" FontSize="11" TextColor="#999" FontAttributes="Bold"/>
                            <Label x:Name="lblDistancia" FontSize="14" TextColor="#333"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Botão: Ligar -->
            <Button x:Name="btnLigar"
                    Margin="16,8"
                    Text="📞 Ligar para a Unidade"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontSize="15"
                    FontAttributes="Bold"
                    Clicked="OnLigarClicked"/>

            <!-- Botão: Voltar para busca -->
            <Button Margin="16,4,16,24"
                    Text="🔙 Buscar outro medicamento"
                    BackgroundColor="White"
                    TextColor="#1565C0"
                    BorderColor="#1565C0"
                    BorderWidth="1"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontSize="15"
                    Clicked="OnVoltarBuscaClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
