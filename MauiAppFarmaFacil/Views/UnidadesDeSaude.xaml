<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MauiAppFarmaFacil.Views.UnidadesDeSaude"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Row 0: Cabeçalho dinâmico com nome do medicamento -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="#1565C0"
                             Padding="16,20,16,16"
                             Spacing="2">
            <Label x:Name="lblTitulo"
                   Text="Unidades com o medicamento"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"/>
            <Label x:Name="lblSubtitulo"
                   TextColor="#BBDEFB"
                   FontSize="13"/>
        </VerticalStackLayout>

        <!-- Row 1: Controle de localização -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="16,10"
              ColumnDefinitions="*,Auto">
            <Label Grid.Column="0"
                   x:Name="lblLocalizacao"
                   Text="📍 Sem localização (ordenação padrão)"
                   VerticalOptions="Center"
                   TextColor="#555"
                   FontSize="13"/>
            <Button Grid.Column="1"
                    Text="Usar minha localização"
                    FontSize="12"
                    BackgroundColor="#E3F2FD"
                    TextColor="#1565C0"
                    CornerRadius="8"
                    Padding="10,6"
                    Clicked="OnUsarLocalizacaoClicked"/>
        </Grid>

        <!-- Row 2: Seção expansível do mapa (oculta até obter localização) -->
        <Border x:Name="secaoMapa"
                Grid.Row="2"
                IsVisible="False"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="0,0,0,2">
            <VerticalStackLayout Spacing="0">

                <!-- Cabeçalho clicável para expandir/colapsar -->
                <Grid BackgroundColor="#E3F2FD"
                      Padding="16,10"
                      ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="🗺️ Ver unidades no mapa"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1565C0"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           x:Name="lblSetaMapa"
                           Text="▼"
                           FontSize="13"
                           TextColor="#1565C0"
                           VerticalOptions="Center"/>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleMapaClicked"/>
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Mapa (visível/oculto pelo toggle) -->
                <maps:Map x:Name="mapaUnidades"
                          IsVisible="False"
                          HeightRequest="260"
                          IsShowingUser="True"
                          MapType="Street"/>

            </VerticalStackLayout>
        </Border>

        <!-- Row 3: Lista de unidades -->
        <CollectionView x:Name="listaUnidades"
                        Grid.Row="3"
                        Margin="0,8,0,0">
            <CollectionView.Header>
                <Label x:Name="lblQtdUnidades"
                       Margin="16,0,16,4"
                       TextColor="#555"
                       FontSize="13"/>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="12,4"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0">
                        <Grid Padding="16,14" RowDefinitions="Auto,Auto,Auto,Auto">

                            <Label Grid.Row="0"
                                   Text="{Binding Nome}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="#1A237E"/>

                            <Label Grid.Row="1"
                                   Text="{Binding Endereco, StringFormat='📍 {0}'}"
                                   FontSize="13"
                                   TextColor="#555"
                                   Margin="0,2,0,0"/>

                            <HorizontalStackLayout Grid.Row="2" Spacing="16" Margin="0,4,0,0">
                                <Label Text="{Binding HorarioFuncionamento, StringFormat='🕐 {0}'}"
                                       FontSize="12"
                                       TextColor="#777"/>
                            </HorizontalStackLayout>

                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                    <Border BackgroundColor="#E8F5E9"
                                            StrokeShape="RoundRectangle 6"
                                            StrokeThickness="0"
                                            Padding="8,3">
                                        <Label Text="{Binding QuantidadeDisponivel, StringFormat='✅ {0} unidades'}"
                                               FontSize="12"
                                               TextColor="#2E7D32"
                                               FontAttributes="Bold"/>
                                    </Border>
                                </HorizontalStackLayout>

                                <Button Grid.Column="1"
                                        Text="Detalhes"
                                        FontSize="12"
                                        BackgroundColor="#1565C0"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnVerDetalhesClicked"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Padding="30" Spacing="10">
                    <Label Text="😔" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="Nenhuma unidade com estoque disponível"
                           FontSize="15"
                           TextColor="#666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Indicador de carregamento (sobrepõe a Row 3) -->
        <ActivityIndicator x:Name="loadingIndicator"
                           Grid.Row="3"
                           IsRunning="False"
                           IsVisible="False"
                           Color="#1565C0"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
    </Grid>
</ContentPage>